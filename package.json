{
  "name": "institute-erp",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "build": "cd frontend && npm install && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "test": "cd backend && python3.11 -m pytest tests/ -v",
    "test:backend": "cd backend && python3.11 -m pytest tests/ -v",
    "test:frontend": "cd frontend && npm test",
    "dev:backend": "cd backend && uvicorn app.main:app --reload --port 5000",
    "dev:frontend": "cd frontend && npm run dev",
    "seed": "cd backend && python3.11 seed.py",
    "start": "cd backend && uvicorn app.main:app --host 0.0.0.0 --port 5000",
    "install:backend": "cd backend && pip install -r requirements.txt",
    "docker:build": "docker build -t institute-erp .",
    "docker:run": "docker compose up -d"
  }
}
