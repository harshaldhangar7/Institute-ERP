generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("STUDENT")
  name      String
  phone     String?
  photo     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student       Student?
  trainer       Trainer?
  counsellor    Counsellor?
  notifications Notification[]
  announcements Announcement[]
}

model Student {
  id             String   @id @default(uuid())
  userId         String   @unique
  batchId        String?
  counsellorId   String?
  enrollmentDate DateTime @default(now())
  mode           String   @default("OFFLINE")

  user        User         @relation(fields: [userId], references: [id])
  batch       Batch?       @relation(fields: [batchId], references: [id])
  counsellor  Counsellor?  @relation(fields: [counsellorId], references: [id])
  attendances Attendance[]
  marks       Marks[]
  mockInterviews MockInterview[]
  submissions Submission[]
  fees        Fee[]
}

model Trainer {
  id             String @id @default(uuid())
  userId         String @unique
  specialization String?

  user           User            @relation(fields: [userId], references: [id])
  trainerBatches TrainerBatch[]
  lectures       Lecture[]
  mockInterviews MockInterview[]
  assignments    Assignment[]
  resources      Resource[]
}

model Counsellor {
  id     String @id @default(uuid())
  userId String @unique

  user              User               @relation(fields: [userId], references: [id])
  counsellorStudents CounsellorStudent[]
  students          Student[]
}

model Batch {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime?
  isActive  Boolean  @default(true)

  students       Student[]
  batchModules   BatchModule[]
  trainerBatches TrainerBatch[]
  lectures       Lecture[]
  assignments    Assignment[]
  announcements  Announcement[]
}

model Module {
  id          String  @id @default(uuid())
  name        String
  description String?
  duration    Int?

  batchModules BatchModule[]
  lectures     Lecture[]
  marks        Marks[]
  assignments  Assignment[]
  resources    Resource[]
}

model BatchModule {
  id               String @id @default(uuid())
  batchId          String
  moduleId         String
  status           String @default("PENDING")
  completionPercent Float  @default(0)

  batch  Batch  @relation(fields: [batchId], references: [id])
  module Module @relation(fields: [moduleId], references: [id])

  @@unique([batchId, moduleId])
}

model TrainerBatch {
  id        String @id @default(uuid())
  trainerId String
  batchId   String

  trainer Trainer @relation(fields: [trainerId], references: [id])
  batch   Batch   @relation(fields: [batchId], references: [id])

  @@unique([trainerId, batchId])
}

model CounsellorStudent {
  id           String @id @default(uuid())
  counsellorId String
  studentId    String

  counsellor Counsellor @relation(fields: [counsellorId], references: [id])

  @@unique([counsellorId, studentId])
}

model Lecture {
  id           String   @id @default(uuid())
  batchId      String
  moduleId     String
  trainerId    String
  date         DateTime
  startTime    String
  endTime      String
  duration     Int?
  topics       String?
  sessionToken String?

  batch       Batch       @relation(fields: [batchId], references: [id])
  module      Module      @relation(fields: [moduleId], references: [id])
  trainer     Trainer     @relation(fields: [trainerId], references: [id])
  attendances Attendance[]
}

model Attendance {
  id        String   @id @default(uuid())
  studentId String
  lectureId String
  status    String   @default("ABSENT")
  markedAt  DateTime @default(now())
  method    String   @default("MANUAL")

  student Student @relation(fields: [studentId], references: [id])
  lecture Lecture  @relation(fields: [lectureId], references: [id])

  @@unique([studentId, lectureId])
}

model Marks {
  id       String  @id @default(uuid())
  studentId String
  moduleId  String
  type      String
  score     Float
  maxScore  Float
  remarks   String?

  student Student @relation(fields: [studentId], references: [id])
  module  Module  @relation(fields: [moduleId], references: [id])
}

model MockInterview {
  id             String   @id @default(uuid())
  studentId      String
  trainerId      String
  date           DateTime
  communication  Float?
  technical      Float?
  confidence     Float?
  overallScore   Float?
  feedback       String?

  student Student @relation(fields: [studentId], references: [id])
  trainer Trainer @relation(fields: [trainerId], references: [id])
}

model Assignment {
  id          String   @id @default(uuid())
  moduleId    String
  batchId     String
  trainerId   String
  title       String
  description String?
  dueDate     DateTime?
  filePath    String?

  module      Module       @relation(fields: [moduleId], references: [id])
  batch       Batch        @relation(fields: [batchId], references: [id])
  trainer     Trainer      @relation(fields: [trainerId], references: [id])
  submissions Submission[]
}

model Submission {
  id           String   @id @default(uuid())
  assignmentId String
  studentId    String
  filePath     String?
  submittedAt  DateTime @default(now())
  grade        String?
  feedback     String?

  assignment Assignment @relation(fields: [assignmentId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])
}

model Resource {
  id         String   @id @default(uuid())
  moduleId   String
  trainerId  String
  title      String
  filePath   String?
  uploadedAt DateTime @default(now())

  module  Module  @relation(fields: [moduleId], references: [id])
  trainer Trainer @relation(fields: [trainerId], references: [id])
}

model Fee {
  id            String   @id @default(uuid())
  studentId     String
  totalAmount   Float
  paidAmount    Float    @default(0)
  pendingAmount Float
  dueDate       DateTime?
  status        String   @default("PENDING")

  student  Student      @relation(fields: [studentId], references: [id])
  payments FeePayment[]
}

model FeePayment {
  id     String   @id @default(uuid())
  feeId  String
  amount Float
  paidAt DateTime @default(now())
  method String

  fee Fee @relation(fields: [feeId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Announcement {
  id         String   @id @default(uuid())
  createdById String
  title      String
  message    String
  targetRole String?
  batchId    String?
  createdAt  DateTime @default(now())

  createdBy User   @relation(fields: [createdById], references: [id])
  batch     Batch? @relation(fields: [batchId], references: [id])
}
